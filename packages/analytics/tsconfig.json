{
  "extends": "@cio/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "baseUrl": ".",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types"],
    "types": ["node"],
    "paths": {
      "@cio/db": ["./node_modules/@cio/db/dist/index.d.ts"],
      "@cio/db/*": ["./node_modules/@cio/db/dist/*"],
      "@cio/utils": ["./node_modules/@cio/utils/dist/index.d.ts"],
      "@cio/utils/*": ["./node_modules/@cio/utils/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tsconfig.tsbuildinfo"],
  "references": [{ "path": "../db" }, { "path": "../utils" }],
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  }
}
