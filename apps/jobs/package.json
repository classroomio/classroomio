{
  "name": "@cio/jobs-worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc && tsc-alias",
    "dev": "pnpm --filter @cio/jobs-worker --parallel \"/^dev:.*/\"",
    "dev:tsc": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:media": "tsx watch src/workers/media.ts",
    "dev:media-transcribe": "tsx watch src/workers/media-transcribe.ts",
    "dev:emails": "tsx watch src/workers/emails.ts",
    "dev:maintenance": "tsx watch src/workers/maintenance.ts",
    "dev:agent-course-generation": "tsx watch src/workers/agent-course-generation.ts",
    "start": "node dist/index.js",
    "start:media": "node dist/workers/media.js",
    "start:media-transcribe": "node dist/workers/media-transcribe.js",
    "start:emails": "node dist/workers/emails.js",
    "start:maintenance": "node dist/workers/maintenance.js",
    "start:agent-course-generation": "node dist/workers/agent-course-generation.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.388.0",
    "@aws-sdk/s3-request-presigner": "^3.675.0",
    "@cio/analytics": "workspace:*",
    "@cio/core": "workspace:*",
    "@cio/db": "workspace:*",
    "@cio/email": "workspace:*",
    "@cio/jobs": "workspace:*",
    "@cio/utils": "workspace:*",
    "bullmq": "^5.34.0",
    "dotenv": "^16.3.1",
    "ioredis": "^5.4.1",
    "openai": "^6.36.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.3",
    "typescript": "^5.5.2",
    "zod": "^4.1.8"
  }
}
