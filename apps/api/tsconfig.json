{
  "compilerOptions": {
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "declaration": true,
    "composite": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": false,
    "skipLibCheck": true,
    "target": "ESNext",
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types", "./src/types"],
    "types": ["node"],
    "paths": {
      "@api/*": ["src/*"],
      "@db/types": ["../../packages/db/src/types.ts"],
      "@db/*": ["../../packages/db/src/*"],
      "@cio/db/*": ["../../packages/db/src/*"],
      "@cio/db/types": ["../../packages/db/src/types.ts"],
      "@cio/utils": ["../../packages/utils/src/index.ts"],
      "@cio/utils/*": ["../../packages/utils/src/*"],
      "@cio/email/*": ["../../packages/email/src/*"],
      "@cio/email": ["../../packages/email/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tsconfig.tsbuildinfo"],
  "references": [
    { "path": "../../packages/db" },
    { "path": "../../packages/utils" },
    { "path": "../../packages/email" }
  ],
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  }
}
