{
  "name": "@cio/docs",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/fetch-openapi.mjs",
    "dev": "node scripts/fetch-openapi.mjs && blume dev",
    "build": "blume build && node scripts/package-assets.mjs",
    "preview": "pnpm run build && wrangler dev --port 4173",
    "deploy": "pnpm run build && wrangler deploy",
    "validate": "blume validate"
  },
  "dependencies": {
    "@astrojs/mdx": "7.0.3",
    "@cio/utils": "workspace:*",
    "@scalar/astro": "0.4.9",
    "@shikijs/twoslash": "4.3.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.1.18",
    "astro": "7.0.9",
    "blume": "1.1.2",
    "mermaid": "^11.16.0",
    "tailwindcss": "4.1.18"
  },
  "devDependencies": {
    "wrangler": "4.86.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
