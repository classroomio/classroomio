{
  "name": "@cio/docs",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/fetch-openapi.mjs",
    "dev": "node scripts/fetch-openapi.mjs && blume dev",
    "build": "blume build && node scripts/package-assets.mjs",
    "preview": "wrangler dev --port 4173",
    "start": "wrangler dev --port 3000",
    "deploy": "pnpm run build && wrangler deploy",
    "validate": "blume validate"
  },
  "dependencies": {
    "@cio/utils": "workspace:*",
    "blume": "1.0.3",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "wrangler": "4.86.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
